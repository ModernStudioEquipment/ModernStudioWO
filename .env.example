# Copy to .env and fill in from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# Leave these BLANK to run the app in local/offline demo mode
# (in-browser localStorage, seeded with sample orders, single machine only).
# Set them to connect the real multi-user Postgres backend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
